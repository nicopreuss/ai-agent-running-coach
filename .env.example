# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=             # Your OpenAI API key (platform.openai.com/api-keys)
OPENAI_MODEL=gpt-4o         # Model name, e.g. gpt-4o, gpt-4o-mini

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=               # e.g. postgresql://user:password@host:5432/dbname

# ── Strava ───────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=           # From strava.com/settings/api
STRAVA_CLIENT_SECRET=       # From strava.com/settings/api
STRAVA_REFRESH_TOKEN=       # Obtained via OAuth flow with scope activity:read
STRAVA_ACCESS_TOKEN=        # Initial access token (auto-refreshed at runtime)

# ── Whoop ─────────────────────────────────────────────────────────────────────
WHOOP_CLIENT_ID=            # From developer.whoop.com
WHOOP_CLIENT_SECRET=        # From developer.whoop.com
WHOOP_REFRESH_TOKEN=        # Obtained via OAuth flow
WHOOP_ACCESS_TOKEN=         # Initial access token (auto-refreshed at runtime)

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=           # From Google Cloud Console
GOOGLE_CLIENT_SECRET=       # From Google Cloud Console
GOOGLE_REFRESH_TOKEN=       # Obtained via OAuth flow with calendar.readonly scope
GOOGLE_CALENDAR_ID=         # The Runna calendar ID (find in Google Calendar settings)

# ── LangSmith tracing ────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=          # LangSmith key — get at smith.langchain.com

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development     # development | staging | production
